# ── Required ──────────────────────────────────────────────
# DATABASE_URL (REQUIRED IN PRODUCTION)
#   Local dev (zero-install SQLite):  file:./dev.db
#   Production (managed Postgres):    postgres://user:pass@host:5432/decisionos
# Migrations are generated for Postgres. For local SQLite, `npm run dev` auto-sets-up
# the client + dev.db (scripts/dev-db.mjs) - no manual prisma steps needed.
DATABASE_URL="file:./dev.db"

# SESSION_SECRET (REQUIRED IN PRODUCTION - the app refuses to start without it)
# Encrypts session JWTs and AES-256-GCM integration secrets. Must be >= 32 chars
# and stable across deploys. Generate with: openssl rand -hex 32
SESSION_SECRET="change-this-to-a-long-random-secret-at-least-32-chars"

# ── Scaling / infrastructure ───────────────────────────────
# REDIS_URL - required when running MORE THAN ONE instance so rate limits are
# shared across replicas (ElastiCache / Memorystore / Azure Cache for Redis).
# Leave unset for single-instance / local dev (falls back to in-memory limits).
# REDIS_URL="redis://localhost:6379"

# DATABASE_POOL_MAX - pg connections per instance (default 5). Keep small and put
# a pooler (RDS Proxy / Cloud SQL connector / PgBouncer) in front for serverless.
# DATABASE_POOL_MAX="5"

# LOG_LEVEL - debug | info | warn | error (default: info in prod, debug in dev).
# LOG_LEVEL="info"

# SENTRY_DSN - error tracking. Leave blank to disable (errors stay in logs).
# When set, error-level logs are forwarded to Sentry with PII/secrets scrubbed.
# SENTRY_DSN="https://...@...ingest.sentry.io/..."
# SENTRY_RELEASE - optional release tag for grouping (e.g. git sha).

# ── Email (review reminders + weekly digest) ───────────────
# Leave blank to disable email (will log to console in dev).
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="you@yourcompany.com"
SMTP_PASS="your-app-password"
SMTP_FROM="decisions@yourcompany.com"

# ── Cron authentication ────────────────────────────────────
# Requests to /api/cron/* must include: Authorization: Bearer <CRON_SECRET>
# Leave blank to allow unauthenticated cron calls (dev only).
CRON_SECRET="a-random-secret-for-cron-routes"

# ── Audit-log retention ────────────────────────────────────
# The append-only security audit trail (AuditLog) is pruned nightly by
# /api/cron/audit-retention. Rows older than this many days are deleted.
# Default is 550 (~18 months). A shorter window favours GDPR data minimization;
# a longer one, a stricter audit commitment. Invalid or non-positive values fall
# back to the default (a bad value never means "delete everything").
AUDIT_RETENTION_DAYS="550"

# ── App URL (for magic links and share page CTA) ───────────
NEXT_PUBLIC_APP_URL="https://your-decisionos-domain.com"

# ── Cookie security ────────────────────────────────────────
# The session cookie is marked `Secure` by default in production, so the browser
# only sends it over HTTPS. If you self-host over plain HTTP or a bare IP (no
# TLS), the browser silently drops the cookie and login "succeeds" but no session
# sticks. Set this to false in that case (and prefer putting TLS in front).
# COOKIE_SECURE="true"

# ── Platform super-admins (provider control plane) ─────────
# Comma-separated emails granted access to the /admin console, where DecisionOS
# staff can see every company (workspace), drop into one to manage it, and
# suspend / re-plan it. This is the ONLY way to grant platform access - it can
# never be set via the database. Fails closed: unset/empty = no platform admins.
# See docs/PLATFORM_ADMIN.md for the full guide.
# PLATFORM_ADMIN_EMAILS="you@decisionos.app,ops@decisionos.app"

# ── AI drafting + "Ask DecisionOS" (optional) ──────────────
# Deployment-wide fallback when a workspace hasn't configured its own Anthropic
# integration in Settings → Integrations. A key is required to enable AI here.
# ANTHROPIC_API_KEY="sk-ant-api03-..."
# ANTHROPIC_MODEL - default model id (defaults to claude-haiku-4-5).
# ANTHROPIC_MODEL="claude-haiku-4-5"
# ANTHROPIC_BASE_URL - point at an Anthropic-compatible endpoint / gateway.
# ANTHROPIC_BASE_URL="https://api.anthropic.com"

# ── Slack capture bot ──────────────────────────────────────
# Register an app at https://api.slack.com/apps with:
#   Slash command:   /decisionos  →  {APP_URL}/api/slack/commands/log
#   Redirect URL:    {APP_URL}/api/slack/oauth/callback
#   Events URL:      {APP_URL}/api/slack/events   (subscribe to reaction_added)
#   Interactivity:   {APP_URL}/api/slack/actions
# Bot scopes: commands, chat:write, users:read, users:read.email,
#   reactions:read, channels:history, groups:history, im:history, mpim:history
# SLACK_CLIENT_ID="1234567890.1234567890"
# SLACK_CLIENT_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# SLACK_SIGNING_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
