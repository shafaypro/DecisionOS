{
  "name": "decision-os",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "predev": "node scripts/dev-db.mjs",
    "dev": "next dev -p 3001",
    "dev:db": "node scripts/dev-db.mjs",
    "prisma:generate": "prisma generate",
    "db:migrate:deploy": "prisma migrate deploy",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force && npm run seed",
    "test:smoke": "tsx tests/smoke/run.ts",
    "test:integration": "vitest run",
    "test": "tsx tests/smoke/run.ts && vitest run",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
